/* OpenClaw Dashboard Styles */

:root {
    --bg-primary: #0f0f23;
    --bg-secondary: #1a1a2e;
    --bg-card: #16162a;
    --bg-hover: #252540;
    --text-primary: #e4e4e7;
    --text-secondary: #a1a1aa;
    --text-muted: #71717a;
    --accent-primary: #6366f1;
    --accent-secondary: #8b5cf6;
    --accent-success: #10b981;
    --accent-warning: #f59e0b;
    --accent-danger: #ef4444;
    --border-color: #27273a;
    --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3);
    --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.4);
    --radius: 12px;
    --radius-sm: 8px;
}

[data-theme="light"] {
    --bg-primary: #f8fafc;
    --bg-secondary: #e2e8f0;
    --bg-card: #ffffff;
    --bg-hover: #f1f5f9;
    --text-primary: #1e293b;
    --text-secondary: #475569;
    --text-muted: #94a3b8;
    --border-color: #e2e8f0;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: var(--bg-primary);
    color: var(--text-primary);
    min-height: 100vh;
    line-height: 1.6;
}

.app {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}

/* Header */
.header {
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-color);
    padding: 1rem 2rem;
    position: sticky;
    top: 0;
    z-index: 100;
}

.header-content {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.logo-icon {
    font-size: 1.5rem;
}

.logo h1 {
    font-size: 1.5rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.btn-icon {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 0.5rem 0.75rem;
    font-size: 1.25rem;
    cursor: pointer;
    transition: all 0.2s ease;
}

.btn-icon:hover {
    background: var(--bg-hover);
    transform: scale(1.05);
}

.status-badge {
    font-size: 0.875rem;
    padding: 0.375rem 0.75rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
}

/* Main */
.main {
    flex: 1;
    padding: 2rem;
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
}

/* Cards Grid - Grille modulaire */
.cards-grid {
    display: grid;
    gap: 0.75rem;
    /* Grille de base : 4 colonnes égales */
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: min-content;
    padding: 0.5rem;
}

/* Cards de différentes tailles */
.card-size-1 {
    /* 1x1 - Card standard */
    grid-column: span 1;
    min-width: 0;
}

.card-size-2 {
    /* 2x1 - Double largeur */
    grid-column: span 2;
    min-width: 0;
}

.card-size-3 {
    /* 2x2 - Double largeur et hauteur */
    grid-column: span 2;
    grid-row: span 2;
    min-width: 0;
}

.card-size-4 {
    /* Full width */
    grid-column: span 4;
    min-width: 0;
}

/* Responsive : sur petit écran tout passe en 1 colonne */
@media (max-width: 1200px) {
    .cards-grid {
        grid-template-columns: repeat(2, 1fr);
    }
    .card-size-4 {
        grid-column: span 2;
    }
}

@media (max-width: 600px) {
    .cards-grid {
        grid-template-columns: 1fr;
    }
    .card-size-1,
    .card-size-2,
    .card-size-3,
    .card-size-4 {
        grid-column: span 1;
        grid-row: span 1;
    }
}

/* Card */
.card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-height: fit-content;
}

.card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
}

.card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.6rem 0.75rem;
    cursor: pointer;
    user-select: none;
    transition: background 0.2s ease;
    min-height: 2.5rem;
}

.card-header:hover {
    background: var(--bg-hover);
}

.card-header.collapsed {
    border-bottom: none;
}

.card-title {
    font-size: 0.95rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
}

.card-icon {
    font-size: 1rem;
}

.card-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.card-toggle {
    font-size: 0.7rem;
    transition: transform 0.3s ease;
    color: var(--text-muted);
    width: 1.5rem;
    height: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
}

.card-header.collapsed .card-toggle {
    transform: rotate(-90deg);
}

.card-content {
    padding: 0.75rem;
    flex: 1;
    overflow: auto;
}

.card-content.collapsed {
    display: none;
    padding: 0;
}

.card-title {
    font-size: 1.125rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.card-icon {
    font-size: 1.25rem;
}

.card-badge {
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-sm);
    background: var(--bg-secondary);
    color: var(--text-secondary);
}

.card-content {
    min-height: 100px;
}

/* Downloads Card */
.downloads-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.download-item {
    background: var(--bg-secondary);
    border-radius: var(--radius-sm);
    padding: 1rem;
    border-left: 4px solid var(--accent-primary);
}

.download-item.completed {
    border-left-color: var(--accent-success);
}

.download-item.downloading {
    border-left-color: var(--accent-warning);
}

.download-header {
    display: flex;
    justify-content: space-between;
    align-items: start;
    margin-bottom: 0.5rem;
}

.download-name {
    font-weight: 500;
    font-size: 0.9375rem;
    word-break: break-word;
    flex: 1;
}

.download-status {
    font-size: 0.75rem;
    padding: 0.125rem 0.5rem;
    border-radius: var(--radius);
    font-weight: 500;
    text-transform: uppercase;
}

.download-status.completed {
    background: rgba(16, 185, 129, 0.2);
    color: var(--accent-success);
}

.download-status.downloading {
    background: rgba(245, 158, 11, 0.2);
    color: var(--accent-warning);
}

.download-meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.875rem;
    color: var(--text-secondary);
}

.download-progress {
    margin-top: 0.75rem;
    height: 6px;
    background: var(--bg-primary);
    border-radius: 3px;
    overflow: hidden;
}

.download-progress-bar {
    height: 100%;
    background: linear-gradient(90deg, var(--accent-primary), var(--accent-secondary));
    border-radius: 3px;
    transition: width 0.3s ease;
}

.download-stats {
    display: flex;
    justify-content: space-between;
    margin-top: 0.5rem;
    font-size: 0.75rem;
    color: var(--text-muted);
}

/* Weather Card */
.weather-current {
    text-align: center;
    padding: 1.5rem;
}

.weather-temp {
    font-size: 3rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.weather-condition {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-top: 0.5rem;
}

.weather-location {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
}

.weather-details {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-color);
}

.weather-detail {
    text-align: center;
}

.weather-detail-value {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary);
}

.weather-detail-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
}

.weather-forecast {
    margin-top: 1.5rem;
    display: flex;
    justify-content: space-around;
    padding-top: 1rem;
    border-top: 1px solid var(--border-color);
}

.forecast-day {
    text-align: center;
    flex: 1;
}

.forecast-date {
    font-size: 0.75rem;
    color: var(--text-muted);
}

.forecast-temps {
    font-size: 0.875rem;
    margin-top: 0.25rem;
}

.forecast-temp-high {
    font-weight: 600;
}

.forecast-temp-low {
    color: var(--text-muted);
}

/* Footer */
.footer {
    padding: 1.5rem;
    text-align: center;
    border-top: 1px solid var(--border-color);
    color: var(--text-muted);
    font-size: 0.875rem;
}

/* Weather Compact */
.weather-compact {
    padding: 0.5rem;
}

.weather-main {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
}

.weather-temp-large {
    font-size: 3rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.weather-info {
    text-align: left;
}

.weather-location-small {
    font-size: 0.75rem;
    color: var(--text-muted);
}

.weather-forecast-compact {
    display: flex;
    justify-content: space-around;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border-color);
    gap: 0.5rem;
}

.weather-forecast-compact .forecast-day {
    text-align: center;
    padding: 0.25rem 0.5rem;
    min-width: 40px;
}

.weather-forecast-compact .forecast-date {
    font-size: 0.7rem;
    color: var(--text-muted);
    text-transform: uppercase;
}

.weather-forecast-compact .forecast-temps {
    font-size: 0.8rem;
}

/* Suggestions Card - Compact */
.suggestions-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.suggestion-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    background: var(--bg-secondary);
    border-radius: var(--radius-sm);
    border-left: 3px solid var(--accent-primary);
    transition: background 0.2s ease;
}

.suggestion-item:hover {
    background: var(--bg-hover);
}

.suggestion-item.film {
    border-left-color: var(--accent-primary);
}

.suggestion-item.serie {
    border-left-color: var(--accent-secondary);
}

.suggestion-item.livre {
    border-left-color: var(--accent-success);
}

.suggestion-icon {
    font-size: 1.5rem;
    line-height: 1;
}

.suggestion-content {
    flex: 1;
    min-width: 0;
}

.suggestion-title {
    font-weight: 500;
    font-size: 0.9rem;
    margin-bottom: 0.125rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.suggestion-meta {
    font-size: 0.75rem;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.suggestion-quality,
.suggestion-platform,
.suggestion-pages {
    font-size: 0.7rem;
    color: var(--text-muted);
}
    color: var(--text-muted);
    margin-top: 0.25rem;
}

.btn-download {
    background: var(--accent-primary);
    border: none;
    border-radius: var(--radius-sm);
    padding: 0.5rem 1rem;
    color: white;
    cursor: pointer;
    transition: background 0.2s ease;
}

.btn-download:hover {
    background: var(--accent-secondary);
}

.suggestion-refresh {
    margin-top: 1.5rem;
    text-align: center;
}

.btn-refresh {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    padding: 0.75rem 1.5rem;
    color: var(--text-primary);
    cursor: pointer;
    transition: all 0.2s ease;
}

.btn-refresh:hover {
    background: var(--bg-hover);
    transform: translateY(-1px);
}

/* Responsive */
@media (max-width: 768px) {
    .cards-grid {
        grid-template-columns: 1fr;
    }
    
    .header {
        padding: 1rem;
    }
    
    .main {
        padding: 1rem;
    }
    
    .logo h1 {
        font-size: 1.25rem;
    }
    
    .weather-temp {
        font-size: 2.5rem;
    }
}

/* Spotify Card Styles */
.spotify-status {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    text-align: center;
    color: var(--text-secondary);
}

.spotify-status-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
    opacity: 0.7;
}

.spotify-status-text {
    font-size: 0.9rem;
}

.spotify-login {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    text-align: center;
}

.spotify-login-header {
    margin-bottom: 1.5rem;
}

.spotify-login-icon {
    font-size: 3rem;
    margin-bottom: 0.5rem;
}

.spotify-login h3 {
    font-size: 1rem;
    color: var(--text-secondary);
    font-weight: 500;
}

.spotify-btn {
    background: linear-gradient(135deg, #1DB954, #1ed760);
    border: none;
    border-radius: var(--radius);
    padding: 0.75rem 1.5rem;
    color: white;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    font-size: 0.9rem;
}

.spotify-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(29, 185, 84, 0.4);
}

.spotify-player {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 0.5rem;
}

.spotify-track-info {
    text-align: center;
    padding: 0.5rem;
}

.spotify-track-info div:first-child {
    font-weight: 600;
    font-size: 1rem;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.spotify-track-info div:last-child {
    font-size: 0.85rem;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.spotify-progress-bar {
    height: 4px;
    background: var(--bg-secondary);
    border-radius: 2px;
    overflow: hidden;
    cursor: pointer;
}

.spotify-progress-bar > div {
    height: 100%;
    background: linear-gradient(90deg, #1DB954, #1ed760);
    border-radius: 2px;
    transition: width 0.3s ease;
}

.spotify-controls {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    padding: 0.5rem 0;
}

.spotify-controls button {
    background: var(--bg-secondary);
    border: none;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    font-size: 1.2rem;
    cursor: pointer;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
}

.spotify-controls button:hover {
    background: var(--bg-hover);
    transform: scale(1.1);
}

.spotify-controls button:nth-child(2) {
    width: 50px;
    height: 50px;
    font-size: 1.5rem;
    background: linear-gradient(135deg, #1DB954, #1ed760);
}

.spotify-controls button:nth-child(2):hover {
    background: linear-gradient(135deg, #1ed760, #1DB954);
}

.spotify-search {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
}

.spotify-search input {
    flex: 1;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 0.5rem 0.75rem;
    color: var(--text-primary);
    font-size: 0.85rem;
}

.spotify-search input:focus {
    outline: none;
    border-color: var(--accent-primary);
}

.spotify-search input::placeholder {
    color: var(--text-muted);
}

.spotify-search button {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 0.5rem 0.75rem;
    cursor: pointer;
    transition: all 0.2s ease;
}

.spotify-search button:hover {
    background: var(--bg-hover);
}

#spotify-search-results {
    max-height: 200px;
    overflow-y: auto;
    margin-top: 0.5rem;
    background: var(--bg-secondary);
    border-radius: var(--radius-sm);
}

#spotify-search-results > div {
    padding: 0.75rem;
    border-bottom: 1px solid var(--border-color);
    cursor: pointer;
    transition: background 0.2s ease;
}

#spotify-search-results > div:hover {
    background: var(--bg-hover);
}

#spotify-search-results > div:last-child {
    border-bottom: none;
}

#spotify-search-results div div:first-child {
    font-weight: 500;
    font-size: 0.9rem;
    color: var(--text-primary);
}

#spotify-search-results div div:last-child {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-top: 0.25rem;
}

/* Animations */
@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
}

.loading {
    animation: pulse 2s infinite;
}

@keyframes slideIn {
    from {
        opacity: 0;
        transform: translateY(10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.card {
    animation: slideIn 0.3s ease-out;
}
